{
  "name": "NAVI-IMS",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "forwardPorts": [8069, 3000, 8288, 8889, 8888, 8100, 3100],

  "portsAttributes": {
    "8069": { "label": "Odoo",            "onAutoForward": "openBrowser" },
    "3000": { "label": "Node + Soldier",  "onAutoForward": "notify" },
    "8288": { "label": "Inngest Dashboard", "onAutoForward": "notify" },
    "8889": { "label": "MediaMTX WebRTC", "onAutoForward": "ignore" },
    "8888": { "label": "MediaMTX HLS",    "onAutoForward": "notify" },
    "8100": { "label": "Inngest Worker",  "onAutoForward": "ignore" },
    "3100": { "label": "Bull Board",      "onAutoForward": "notify" }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
