<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Maintenance Request ═══ -->

    <record id="maintenance_request_view_tree" model="ir.ui.view">
        <field name="name">patrol.maintenance.request.tree</field>
        <field name="model">patrol.maintenance.request</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority == '3'"
                  decoration-warning="priority == '2'"
                  decoration-muted="state in ('verified','cancelled')">
                <field name="code"/>
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="equipment_type"/>
                <field name="maintenance_type"/>
                <field name="priority"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'new'"
                       decoration-warning="state == 'assigned'"
                       decoration-primary="state == 'in_progress'"
                       decoration-success="state in ('done','verified')"
                       decoration-danger="state == 'cancelled'"/>
                <field name="technician_id"/>
                <field name="request_date"/>
                <field name="duration" widget="float_time"/>
                <field name="total_cost"/>
            </list>
        </field>
    </record>

    <record id="maintenance_request_view_form" model="ir.ui.view">
        <field name="name">patrol.maintenance.request.form</field>
        <field name="model">patrol.maintenance.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_assign" string="มอบหมายช่าง" type="object"
                            invisible="state != 'new'" class="btn-primary"/>
                    <button name="action_start" string="เริ่มซ่อม" type="object"
                            invisible="state != 'assigned'" class="btn-primary"/>
                    <button name="action_done" string="ซ่อมเสร็จ" type="object"
                            invisible="state != 'in_progress'" class="btn-success"/>
                    <button name="action_verify" string="ตรวจรับ" type="object"
                            invisible="state != 'done'" class="btn-success"/>
                    <button name="action_cancel" string="ยกเลิก" type="object"
                            invisible="state in ('verified','cancelled')" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,assigned,in_progress,done,verified"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="code" class="oe_inline me-2" readonly="1"/>
                            <field name="name" placeholder="เรื่องแจ้งซ่อม"/>
                        </h1>
                    </div>
                    <group>
                        <group string="อุปกรณ์">
                            <field name="equipment_id"/>
                            <field name="equipment_type"/>
                            <field name="maintenance_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="mission_id"/>
                        </group>
                        <group string="ผู้เกี่ยวข้อง">
                            <field name="requested_by"/>
                            <field name="technician_id"/>
                            <field name="verified_by" invisible="state != 'verified'"/>
                        </group>
                    </group>
                    <group>
                        <group string="เวลา">
                            <field name="request_date"/>
                            <field name="schedule_date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="verified_date" invisible="state != 'verified'"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                        <group string="ค่าใช้จ่าย">
                            <field name="total_part_cost"/>
                            <field name="labor_cost"/>
                            <field name="total_cost"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="อาการ">
                            <field name="description" placeholder="อาการที่พบ..."/>
                        </page>
                        <page string="การแก้ไข">
                            <field name="cause" placeholder="สาเหตุ..."/>
                            <field name="resolution" placeholder="วิธีแก้ไข..."/>
                        </page>
                        <page string="อะไหล่">
                            <field name="part_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="part_number"/>
                                    <field name="quantity"/>
                                    <field name="unit_cost"/>
                                    <field name="cost"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="maintenance_request_view_kanban" model="ir.ui.view">
        <field name="name">patrol.maintenance.request.kanban</field>
        <field name="model">patrol.maintenance.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="code"/>
                <field name="name"/>
                <field name="equipment_id"/>
                <field name="maintenance_type"/>
                <field name="priority"/>
                <field name="technician_id"/>
                <templates>
                    <t t-name="card">
                        <field name="priority" widget="priority"/>
                        <strong><field name="code"/></strong>
                        <div><field name="name"/></div>
                        <div class="text-muted">
                            <field name="equipment_id"/> — <field name="maintenance_type"/>
                        </div>
                        <div t-if="record.technician_id.value" class="mt-1">
                            ช่าง: <field name="technician_id"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="maintenance_request_action" model="ir.actions.act_window">
        <field name="name">ใบแจ้งซ่อม</field>
        <field name="res_model">patrol.maintenance.request</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <!-- ═══ Maintenance Schedule ═══ -->

    <record id="maintenance_schedule_view_tree" model="ir.ui.view">
        <field name="name">patrol.maintenance.schedule.tree</field>
        <field name="model">patrol.maintenance.schedule</field>
        <field name="arch" type="xml">
            <list decoration-danger="next_date and next_date &lt; current_date">
                <field name="equipment_id"/>
                <field name="name"/>
                <field name="interval_number"/>
                <field name="interval_type"/>
                <field name="last_done_date"/>
                <field name="next_date"/>
                <button name="action_create_request" string="สร้างใบแจ้งซ่อม"
                        type="object" icon="fa-wrench"/>
            </list>
        </field>
    </record>

    <record id="maintenance_schedule_view_form" model="ir.ui.view">
        <field name="name">patrol.maintenance.schedule.form</field>
        <field name="model">patrol.maintenance.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="interval_number"/>
                            <field name="interval_type"/>
                            <field name="last_done_date"/>
                            <field name="next_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="maintenance_schedule_action" model="ir.actions.act_window">
        <field name="name">แผนซ่อมบำรุง</field>
        <field name="res_model">patrol.maintenance.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══ Menus ═══ -->

    <menuitem id="menu_patrol_maintenance"
              name="ซ่อมบำรุง"
              parent="menu_patrol_root"
              sequence="30"/>

    <menuitem id="menu_maintenance_request"
              name="ใบแจ้งซ่อม"
              parent="menu_patrol_maintenance"
              action="maintenance_request_action"
              sequence="10"/>

    <menuitem id="menu_maintenance_schedule"
              name="แผนซ่อมบำรุง"
              parent="menu_patrol_maintenance"
              action="maintenance_schedule_action"
              sequence="20"/>

    <!-- ═══ Sequence ═══ -->

    <record id="seq_maintenance_request" model="ir.sequence">
        <field name="name">Maintenance Request</field>
        <field name="code">patrol.maintenance.request</field>
        <field name="prefix">MNT-%(year)s-</field>
        <field name="padding">4</field>
    </record>

    <!-- ═══ Equipment form — เพิ่ม tab ซ่อมบำรุง ═══ -->

    <record id="patrol_equipment_view_form_maint" model="ir.ui.view">
        <field name="name">patrol.equipment.form.maintenance</field>
        <field name="model">patrol.equipment</field>
        <field name="inherit_id" ref="patrol_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='gps_lng']" position="after">
                <field name="maintenance_count"/>
                <field name="next_maintenance"/>
            </xpath>
        </field>
    </record>

</odoo>
