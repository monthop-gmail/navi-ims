<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="patrol_soldier_view_tree" model="ir.ui.view">
        <field name="name">patrol.soldier.tree</field>
        <field name="model">patrol.soldier</field>
        <field name="arch" type="xml">
            <list decoration-success="is_online == True" decoration-muted="is_online == False">
                <field name="callsign"/>
                <field name="rank"/>
                <field name="name"/>
                <field name="unit_id"/>
                <field name="is_online"/>
                <field name="active_mission_id"/>
                <field name="last_gps_time"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="patrol_soldier_view_form" model="ir.ui.view">
        <field name="name">patrol.soldier.form</field>
        <field name="model">patrol.soldier</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="callsign" placeholder="สัญญาณเรียกขาน"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="rank"/>
                            <field name="unit_id"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="is_online"/>
                            <field name="stream_path"/>
                            <field name="active_mission_id"/>
                            <field name="last_lat"/>
                            <field name="last_lng"/>
                            <field name="last_gps_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="อุปกรณ์">
                            <field name="equipment_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="equipment_type"/>
                                    <field name="state"/>
                                    <field name="is_streaming"/>
                                </list>
                            </field>
                        </page>
                        <page string="ภารกิจ">
                            <field name="mission_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="date_start"/>
                                </list>
                            </field>
                        </page>
                        <page string="เหตุการณ์">
                            <field name="incident_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="incident_type"/>
                                    <field name="severity"/>
                                    <field name="state"/>
                                    <field name="date_reported"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="patrol_soldier_view_kanban" model="ir.ui.view">
        <field name="name">patrol.soldier.kanban</field>
        <field name="model">patrol.soldier</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="callsign"/>
                <field name="name"/>
                <field name="rank"/>
                <field name="is_online"/>
                <field name="unit_id"/>
                <field name="photo"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex">
                            <field name="photo" widget="image" class="o_kanban_image"/>
                            <div class="ms-2">
                                <strong>
                                    <field name="callsign"/>
                                </strong>
                                <div><field name="name"/></div>
                                <div class="text-muted"><field name="unit_id"/></div>
                                <span t-if="record.is_online.raw_value" class="badge text-bg-success">Online</span>
                                <span t-else="" class="badge text-bg-secondary">Offline</span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="patrol_soldier_action" model="ir.actions.act_window">
        <field name="name">กำลังพล</field>
        <field name="res_model">patrol.soldier</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

    <menuitem id="menu_patrol_soldier"
              name="กำลังพล"
              parent="menu_patrol_resources"
              action="patrol_soldier_action"
              sequence="10"/>
</odoo>
