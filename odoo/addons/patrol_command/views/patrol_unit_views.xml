<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="patrol_unit_view_tree" model="ir.ui.view">
        <field name="name">patrol.unit.tree</field>
        <field name="model">patrol.unit</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="unit_type"/>
                <field name="parent_id"/>
                <field name="commander_id"/>
                <field name="soldier_count"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="patrol_unit_view_form" model="ir.ui.view">
        <field name="name">patrol.unit.form</field>
        <field name="model">patrol.unit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="unit_type"/>
                        </group>
                        <group>
                            <field name="parent_id"/>
                            <field name="commander_id"/>
                            <field name="soldier_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="กำลังพล">
                            <field name="soldier_ids">
                                <list>
                                    <field name="callsign"/>
                                    <field name="rank"/>
                                    <field name="name"/>
                                    <field name="is_online"/>
                                </list>
                            </field>
                        </page>
                        <page string="หน่วยรอง">
                            <field name="child_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="unit_type"/>
                                    <field name="soldier_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="patrol_unit_action" model="ir.actions.act_window">
        <field name="name">โครงสร้างหน่วย</field>
        <field name="res_model">patrol.unit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_patrol_unit"
              name="โครงสร้างหน่วย"
              parent="menu_patrol_config"
              action="patrol_unit_action"
              sequence="10"/>
</odoo>
